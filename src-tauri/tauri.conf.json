{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Soia",
  "version": "0.1.4",
  "identifier": "com.soia.player",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Soia",
        "width": 1280,
        "height": 720,
        "decorations": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMxQ0I1Mzg2Q0MwOUE4MkUKUldRdXFBbk1obFBMTVIxOFM5cnJ1bkNLU09ieGZZdDNyeUNRKzdDTUNieVVsK1g3TGNMVEJNNXEK",
      "endpoints": [
        "https://github.com/FengZeng/soia/releases/latest/download/latest.json"
      ]
    }
  }
}
